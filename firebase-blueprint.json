{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile data including gamification stats",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "User's display name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "age": { "type": "number", "description": "User's age" },
        "weight": { "type": "number", "description": "User's weight in kg" },
        "goal": { "type": "string", "enum": ["Weight Loss", "Muscle Gain", "Maintain"], "description": "Fitness goal" },
        "xp": { "type": "number", "description": "Total experience points" },
        "level": { "type": "number", "description": "Current level based on XP" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["email", "xp", "level"]
    },
    "StepRecord": {
      "title": "StepRecord",
      "description": "Daily step tracking record",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user who owns this record" },
        "date": { "type": "string", "description": "Date string in YYYY-MM-DD format" },
        "steps": { "type": "number", "description": "Number of steps taken" },
        "calories": { "type": "number", "description": "Calories burned from steps" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp" }
      },
      "required": ["userId", "date", "steps", "calories"]
    },
    "WorkoutRecord": {
      "title": "WorkoutRecord",
      "description": "Individual workout session record",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user who performed the workout" },
        "type": { "type": "string", "enum": ["Pushups", "Squats", "Running"], "description": "Type of workout" },
        "duration": { "type": "number", "description": "Duration in seconds" },
        "calories": { "type": "number", "description": "Calories burned" },
        "xpEarned": { "type": "number", "description": "XP earned from this workout" },
        "date": { "type": "string", "format": "date-time", "description": "Timestamp of the workout" }
      },
      "required": ["userId", "type", "duration", "calories", "xpEarned", "date"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Stores user profiles"
    },
    "/steps/{stepId}": {
      "schema": { "$ref": "#/entities/StepRecord" },
      "description": "Stores daily step records. Document ID is typically userId_YYYY-MM-DD"
    },
    "/workouts/{workoutId}": {
      "schema": { "$ref": "#/entities/WorkoutRecord" },
      "description": "Stores individual workout sessions"
    }
  }
}
